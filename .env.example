# 后端读取的环境变量示例。复制为 .env 后填入真实值，真实 .env 不要公开。
HIGHLIGHTLY_BASE_URL=https://soccer.highlightly.net
HIGHLIGHTLY_API_KEY=填你的Highlightly API Key

# 如果你使用 RapidAPI 版本，再打开这一项。
# HIGHLIGHTLY_RAPIDAPI_HOST=football-highlights-api.p.rapidapi.com

# 管理接口 token。生产环境务必设置，前端不会读取它。
ADMIN_TOKEN=换成一串足够长的随机字符串

# 免费版每日请求上限，默认 100。
HIGHLIGHTLY_DAILY_LIMIT=100
